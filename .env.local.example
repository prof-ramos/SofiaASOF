# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Somente para o script de ingestão; nunca expor no cliente

# Portal da Transparência — https://portaldatransparencia.gov.br/api-de-dados/cadastrar
PORTAL_TRANSPARENCIA_API_KEY=your-api-key-here
