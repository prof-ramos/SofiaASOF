# ==============================================================================
# DEPENDENCIES
# ==============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-debug.log*

# ==============================================================================
# NEXT.JS (v16)
# ==============================================================================
/.next/
/out/
/.next-turbo/
.next/

# ==============================================================================
# PRODUCTION BUILD
# ==============================================================================
/build
/dist

# ==============================================================================
# TESTING
# ==============================================================================
/coverage
.nyc_output
/test-results
/vitest-stats

# ==============================================================================
# ENVIRONMENT FILES
# ==============================================================================
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local
# .env.local.example é versionado intencionalmente
.env.example

# ==============================================================================
# TYPESCRIPT
# ==============================================================================
*.tsbuildinfo
next-env.d.ts
*.d.ts.ts
*.ts.ts

# ==============================================================================
# IDES & EDITORS
# ==============================================================================
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ==============================================================================
# DEBUG & LOGS
# ==============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
logs/
*.log.gz

# ==============================================================================
# OS & TEMP FILES
# ==============================================================================
*.pem
*.pid
*.seed
*.pid.lock
.npm
.eslintcache
.stylelintcache
.prettierignore

# ==============================================================================
# DATABASE (Supabase local)
# ==============================================================================
supabase/.branches
supabase/.temp
supabase/logs
supabase/.env.local
supabase/config.toml.local

# ==============================================================================
# BACKUP & TEMP FILES
# ==============================================================================
*.bak
*.backup
*.old
*.orig
*.rej
.~*
\#*\#

# ==============================================================================
# VERCEL & DEPLOYMENT
# ==============================================================================
.vercel
.vercel_backup
.dist ZIP

# ==============================================================================
# DOCUMENTOS (sensíveis / peso)
# ==============================================================================
/docs/*.txt
/docs/*.pdf
/docs/*.docx
/docs/*.doc
!/docs/.gitkeep

# ==============================================================================
# OMC STATE & GENERATED REPORTS
